{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.1.2",
  "description": "__MSG_extDesc__",
  "default_locale": "en",
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "activeTab",
    "webNavigation",
    "alarms"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "core_1",
        "enabled": true,
        "path": "rulesets/rules_core_1.json"
      },
      {
        "id": "core_2",
        "enabled": true,
        "path": "rulesets/rules_core_2.json"
      },
      {
        "id": "china_1",
        "enabled": false,
        "path": "rulesets/rules_china_1.json"
      },
      {
        "id": "china_2",
        "enabled": false,
        "path": "rulesets/rules_china_2.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content/collapse.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "just-ad-blocker@local",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}